; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="ROR Testing"
run/main_scene="uid://cqyjg1x55n0jr"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=144
boot_splash/image="uid://bts1p38b5qivq"

[autoload]

GameManager="*res://scripts/main/game_manager.gd"

[debug]

gdscript/warnings/unassigned_variable_op_assign=2
gdscript/warnings/unused_local_constant=0
gdscript/warnings/unused_parameter=0
gdscript/warnings/integer_division=0
gdscript/warnings/narrowing_conversion=0

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/initial_position_type=3
window/stretch/mode="canvas_items"

[editor]

naming/node_name_casing=2
version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://assets/": "red",
"res://assets/buildings/": "red",
"res://assets/hexs/": "red",
"res://assets/legacy/": "gray",
"res://assets/menus/": "gray",
"res://balancing/": "teal",
"res://scenes/": "purple",
"res://scenes/legacy/": "gray",
"res://scripts/": "pink",
"res://scripts/menus/": "gray",
"res://text_files/": "gray"
}

[gui]

theme/default_font_multichannel_signed_distance_field=true

